      "pinyin": "tónghuà lǐ dōu shì piàn rén de",
      "type": "lyric"
    },
    {
      "raw": "我不可能 wǒ bùkěnéng",
      "chinese": "我不可能",
      "pinyin": "wǒ bùkěnéng",
      "type": "lyric"
    },
    {
