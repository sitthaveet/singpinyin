    },
    {
      "raw": "當我們不在一起 dāng wǒ men bù zài yī qǐ",
      "chinese": "當我們不在一起",
      "pinyin": "dāng wǒ men bù zài yī qǐ",
      "type": "lyric"
    },
    {
      "raw": "當烏雲泄露了雨 dāng wū yún xiè lòu le yǔ",
      "chinese": "當烏雲泄露了雨",
      "pinyin": "dāng wū yún xiè lòu le yǔ",
      "type": "lyric"
    },
    {
      "raw": "溫濕的空氣 wēn shī de kōng qì",
      "chinese": "溫濕的空氣",
      "pinyin": "wēn shī de kōng qì",
      "type": "lyric"
    },
    {
      "raw": "讓某人 ràng mǒu rén",
      "chinese": "讓某人",
      "pinyin": "ràng mǒu rén",
      "type": "lyric"
    },
    {
      "raw": "滯留在原地 zhì liú zài yuán dì",
      "chinese": "滯留在原地",
      "pinyin": "zhì liú zài yuán dì",
      "type": "lyric"
    },
    {
      "raw": "淋著雨尋覓 lín zhe yǔ xún mì",
      "chinese": "淋著雨尋覓",
      "pinyin": "lín zhe yǔ xún mì",
      "type": "lyric"
    },
    {
      "raw": "你消失的痕迹 nǐ xiāo shī de hén jī",
      "chinese": "你消失的痕迹",
      "pinyin": "nǐ xiāo shī de hén jī",
      "type": "lyric"
    },
    {
      "raw": "",
      "chinese": "",
      "pinyin": "",
      "type": "blank"
    },
    {
      "raw": "當雷聲突然響起 dāng léi shēng tú rán xiǎng qǐ",
      "chinese": "當雷聲突然響起",
      "pinyin": "dāng léi shēng tú rán xiǎng qǐ",
      "type": "lyric"
    },
    {
      "raw": "當我又把你想起 dāng wǒ yòu bǎ nǐ xiǎng qǐ",
      "chinese": "當我又把你想起",
      "pinyin": "dāng wǒ yòu bǎ nǐ xiǎng qǐ",
      "type": "lyric"
    },
    {
      "raw": "當好久沒再聯系 dāng hǎo jiǔ méi zài lián xì",
      "chinese": "當好久沒再聯系",
      "pinyin": "dāng hǎo jiǔ méi zài lián xì",
      "type": "lyric"
    },
    {
      "raw": "你銷聲匿迹 nǐ xiāo shēng nì jì",
      "chinese": "你銷聲匿迹",
      "pinyin": "nǐ xiāo shēng nì jì",
      "type": "lyric"
    },
    {
      "raw": "沒有人知道你蹤迹 méi yǒu rén zhī dào nǐ zōng jī",
      "chinese": "沒有人知道你蹤迹",
      "pinyin": "méi yǒu rén zhī dào nǐ zōng jī",
      "type": "lyric"
    },
    {
      "raw": "這算不算是逃避 zhè suàn bù suàn shì táo bì",
      "chinese": "這算不算是逃避",
      "pinyin": "zhè suàn bù suàn shì táo bì",
      "type": "lyric"
    },
    {
      "raw": "就與我爲敵 jiù yǔ wǒ wèi dí",
      "chinese": "就與我爲敵",
      "pinyin": "jiù yǔ wǒ wèi dí",
      "type": "lyric"
    },
