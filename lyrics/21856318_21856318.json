      "type": "blank"
    },
    {
      "raw": "你 别说你的心里 nǐ ,bié shuō nǐ de xīn lǐ",
      "chinese": "你 别说你的心里",
      "pinyin": "nǐ ,bié shuō nǐ de xīn lǐ",
      "type": "lyric"
    },
    {
      "raw": "还有我 hái yǒu wǒ",
      "chinese": "还有我",
      "pinyin": "hái yǒu wǒ",
      "type": "lyric"
    },
    {
      "raw": "只是 暂时没人 zhǐ shì ,zhàn shí méi rén",
      "chinese": "只是 暂时没人",
      "pinyin": "zhǐ shì ,zhàn shí méi rén",
      "type": "lyric"
    },
    {
      "raw": "比我更适合 bǐ wǒ gèng shì hé",
      "chinese": "比我更适合",
      "pinyin": "bǐ wǒ gèng shì hé",
      "type": "lyric"
    },
    {
      "raw": "当初 dāng chū",
      "chinese": "当初",
      "pinyin": "dāng chū",
      "type": "lyric"
    },
    {
      "raw": "在我满眼是你 zài wǒ mǎn yǎn shì nǐ",
      "chinese": "在我满眼是你",
      "pinyin": "zài wǒ mǎn yǎn shì nǐ",
      "type": "lyric"
    },
    {
      "raw": "的时候 de shí hòu",
      "chinese": "的时候",
      "pinyin": "de shí hòu",
      "type": "lyric"
    },
    {
      "raw": "也没有被你 yě méi yǒu bèi nǐ",
      "chinese": "也没有被你",
      "pinyin": "yě méi yǒu bèi nǐ",
      "type": "lyric"
    },
    {
      "raw": "好好珍惜过 hǎo hǎo zhēn xī guò",
      "chinese": "好好珍惜过",
      "pinyin": "hǎo hǎo zhēn xī guò",
      "type": "lyric"
    },
    {
      "raw": "",
