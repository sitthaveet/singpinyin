    {
      "raw": "",
      "chinese": "",
      "pinyin": "",
      "type": "blank"
    },
    {
      "raw": "凭什么你回头 píng shén me nǐ huí tóu",
      "chinese": "凭什么你回头",
      "pinyin": "píng shén me nǐ huí tóu",
      "type": "lyric"
    },
    {
      "raw": "我就要在身后 wǒ jiù yào zài shēn hòu",
      "chinese": "我就要在身后",
      "pinyin": "wǒ jiù yào zài shēn hòu",
      "type": "lyric"
    },
    {
      "raw": "需要你的时候 xū yào nǐ de shí hòu",
      "chinese": "需要你的时候",
      "pinyin": "xū yào nǐ de shí hòu",
      "type": "lyric"
    },
    {
      "raw": "你都不在我左右 nǐ dōu bù zài wǒ zuǒ yòu",
      "chinese": "你都不在我左右",
      "pinyin": "nǐ dōu bù zài wǒ zuǒ yòu",
      "type": "lyric"
    },
    {
      "raw": "不懂珍惜的人 bù dǒng zhēn xī de rén",
      "chinese": "不懂珍惜的人",
      "pinyin": "bù dǒng zhēn xī de rén",
      "type": "lyric"
    },
    {
      "raw": "幸福得好轻松 xìng fú dé hǎo qīng sōng",
      "chinese": "幸福得好轻松",
      "pinyin": "xìng fú dé hǎo qīng sōng",
      "type": "lyric"
    },
    {
      "raw": "反而是揣 fǎn'ér shì chuāi",
      "chinese": "反而是揣",
      "pinyin": "fǎn'ér shì chuāi",
      "type": "lyric"
    },
    {
      "raw": "着真诚的人 zhe zhēn chéng de rén",
      "chinese": "着真诚的人",
      "pinyin": "zhe zhēn chéng de rén",
      "type": "lyric"
    },
    {
      "raw": "在心痛 zài xīn tòng",
      "chinese": "在心痛",
      "pinyin": "zài xīn tòng",
      "type": "lyric"
    },
    {
      "raw": "",
      "chinese": "",
      "pinyin": "",
      "type": "blank"
    },
    {
      "raw": "于是我不回头 yú shì wǒ bù huí tóu",
      "chinese": "于是我不回头",
      "pinyin": "yú shì wǒ bù huí tóu",
      "type": "lyric"
    },
    {
      "raw": "这次换我先走 zhè cì huàn wǒ xiān zǒu",
      "chinese": "这次换我先走",
      "pinyin": "zhè cì huàn wǒ xiān zǒu",
      "type": "lyric"
    },
    {
      "raw": "反正我早就习惯 fǎn zhèng wǒ zǎo jiù xí guàn",
