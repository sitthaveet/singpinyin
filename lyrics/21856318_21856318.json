      "type": "lyric"
    },
    {
      "raw": "是你先推开我 shì nǐ xiān tuī kāi wǒ",
      "chinese": "是你先推开我",
      "pinyin": "shì nǐ xiān tuī kāi wǒ",
      "type": "lyric"
    },
    {
      "raw": "怎么 现在又要 zěn me ,xiàn zài yòu yào",
      "chinese": "怎么 现在又要",
      "pinyin": "zěn me ,xiàn zài yòu yào",
      "type": "lyric"
    },
    {
      "raw": "回头来找我 huí tóu lái zhǎo wǒ",
      "chinese": "回头来找我",
      "pinyin": "huí tóu lái zhǎo wǒ",
      "type": "lyric"
    },
    {
      "raw": "可我 好不容易 kě wǒ ,hǎo bù róng yì",
      "chinese": "可我 好不容易",
      "pinyin": "kě wǒ ,hǎo bù róng yì",
      "type": "lyric"
    },
    {
      "raw": "才走出来的 cái zǒu chū lái de",
      "chinese": "才走出来的",
      "pinyin": "cái zǒu chū lái de",
      "type": "lyric"
    },
    {
      "raw": "你不该再打扰我 nǐ bù gāi zài dǎ rǎo wǒ",
      "chinese": "你不该再打扰我",
      "pinyin": "nǐ bù gāi zài dǎ rǎo wǒ",
      "type": "lyric"
    },
    {
      "raw": "的生活 de shēng huó",
      "chinese": "的生活",
      "pinyin": "de shēng huó",
      "type": "lyric"
    },
    {
